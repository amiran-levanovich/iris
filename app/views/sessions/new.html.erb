<span class="auth-brand"><%= t("layouts.application.brand") %></span>

<div class="auth-card">
  <h1><%= t(".title") %></h1>

  <%= form_with url: session_path do |form| %>
    <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: t(".email_placeholder"), value: params[:email_address] %>
    <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: t(".password_placeholder"), maxlength: 72 %>
    <%= form.submit t(".sign_in") %>
  <% end %>

  <div class="auth-links">
    <%= link_to t(".forgot_password"), new_password_path %>
  </div>
</div>
