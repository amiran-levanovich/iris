<div class="page-head">
  <h1><%= t(".title", property: @property.name) %></h1>
  <%= link_to t(".new_reservation"), new_property_reservation_path(@property), class: "btn" %>
</div>

<% groups = { arrivals: @arrivals, departures: @departures, in_house: @in_house } %>

<% groups.each do |name, reservations| %>
  <div class="page-head">
    <h2><%= t(".#{name}") %></h2>
  </div>

  <% if reservations.any? %>
    <table class="room-board">
      <thead>
        <tr>
          <th><%= Reservation.human_attribute_name(:guest) %></th>
          <th><%= Room.human_attribute_name(:number) %></th>
          <th><%= Reservation.human_attribute_name(:check_in_on) %></th>
          <th><%= Reservation.human_attribute_name(:check_out_on) %></th>
          <th><%= Reservation.human_attribute_name(:status) %></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <%= render partial: "reservation", collection: reservations %>
      </tbody>
    </table>
  <% else %>
    <p class="empty"><%= t(".empty_#{name}") %></p>
  <% end %>
<% end %>

<%= link_to t(".back"), property_path(@property), class: "back-link" %>
