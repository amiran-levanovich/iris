<h1><%= t(".title", property: @property.name) %></h1>

<%= form_with url: property_reservations_path(@property), scope: :reservation, class: "form",
      data: { controller: "availability", availability_url_value: new_property_reservation_path(@property) } do |form| %>
  <% if @reservation %><%= render "shared/form_errors", record: @reservation %><% end %>

  <div class="field-row">
    <div>
      <%= form.label :check_in_on, Reservation.human_attribute_name(:check_in_on) %>
      <%= form.date_field :check_in_on, value: @stay_period.check_in,
            data: { availability_target: "date", action: "availability#refresh" } %>
    </div>
    <div>
      <%= form.label :check_out_on, Reservation.human_attribute_name(:check_out_on) %>
      <%= form.date_field :check_out_on, value: @stay_period.check_out,
            data: { availability_target: "date", action: "availability#refresh" } %>
    </div>
  </div>

  <%= render "guests/picker" %>

  <div>
    <%= form.label :room_id, Reservation.human_attribute_name(:room) %>
    <%= turbo_frame_tag "available_rooms" do %>
      <%= render "reservations/available_rooms", rooms: @rooms %>
    <% end %>
  </div>

  <div>
    <%= form.submit t(".book") %>
  </div>
<% end %>

<%= link_to t(".back"), property_path(@property), class: "back-link" %>
